# Google Ads Agent API — Environment Variables
# Copy to .env and fill in real values before running.

# ── API Security ──────────────────────────────────────────────────────────────
# API key for admin endpoints (choose a strong random string)
ADMIN_API_KEY=CHANGE_ME

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://adsagent:CHANGE_ME@localhost:5432/ads_agent
DB_PROVIDER=postgresql

# ── Google Ads (MCC) ────────────────────────────────────────────────────────
# Obtain from Google Cloud Console > APIs & Services > Credentials
GOOGLE_ADS_DEVELOPER_TOKEN=CHANGE_ME
GOOGLE_ADS_CLIENT_ID=CHANGE_ME
GOOGLE_ADS_CLIENT_SECRET=CHANGE_ME
GOOGLE_ADS_REFRESH_TOKEN=CHANGE_ME
GOOGLE_ADS_CUSTOMER_ID=CHANGE_ME

# ── LLM ───────────────────────────────────────────────────────────────────────
# LLM provider: minimax (default), openai, or anthropic
LLM_PROVIDER=minimax
# MiniMax API key from https://platform.minimax.chat
MINIMAX_API_KEY=CHANGE_ME
MINIMAX_BASE_URL=https://api.minimax.chat
MINIMAX_MODEL=MiniMax-Text-01

# ── MCP Server ─────────────────────────────────────────────────────────────
# Path to the MCP server executable (used by agents to call Google Ads)
MCP_SERVER_PATH=/opt/ads-agent/mcp_server.py

# ── Research Cycle ───────────────────────────────────────────────────────────
# Cron expression for daily research (default: 8am server time)
RESEARCH_CRON=0 8 * * *
# Maximum debate rounds before flagging for manual review
MAX_DEBATE_ROUNDS=5

# ── HITL / Email (Human-in-the-Loop) ────────────────────────────────────────
# Enable HITL email approval for high-impact proposals
HITL_ENABLED=true
# Resend API key for sending and receiving emails
RESEND_API_KEY=CHANGE_ME
# Inbound secret (from Resend webhook configuration)
RESEND_INBOUND_SECRET=CHANGE_ME
# Default sender email for HITL approvals
HITL_DEFAULT_EMAIL=CHANGE_ME
# Days before a pending HITL proposal expires
HITL_PROPOSAL_TTL_DAYS=7
# Cron expression for weekly digest (default: every 5 min — adjust as needed)
HITL_WEEKLY_CRON=*/5 * * * *
